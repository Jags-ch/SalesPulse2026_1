<mvc:View controllerName="salespulse360.app.controller.Dashboard" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:viz="sap.viz.ui5.controls" xmlns:vds="sap.viz.ui5.data" xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
  <Page showHeader="true" title="{i18n>dashboard.title}">
    <content>
          <VBox fitContainer="true" width="100%">
            <HBox class="sapUiSmallMargin" alignItems="Center" justifyContent="SpaceBetween">
              <Text text="Total Revenue" class="sapUiSmallMargin" />
              <Select selectedKey="{view>/RevenueChartPeriod}" change="onRevenuePeriodChange" width="200px">
                <items>
                  <core:Item key="daily" text="Daily" />
                  <core:Item key="weekly" text="Weekly" />
                  <core:Item key="monthly" text="Monthly" />
                  <core:Item key="quarterly" text="Quarterly" />
                  <core:Item key="yearly" text="Yearly" />
                </items>
              </Select>
            </HBox>
            <VBox class="sapUiSmallMargin">
              <HBox class="sapUiSmallMargin" justifyContent="Center" alignItems="Center" width="100%">
                <VBox class="sapUiSmallMargin" alignItems="Center">
                  <Text text="Total Revenue" class="sapUiSmallMargin" />
                  <Text text="{view>/RevenueTotalDisplay}" class="sapUiLargeMargin" />
                </VBox>
              </HBox>
            </VBox>
            <HBox class="sapUiSmallMargin">
              <VBox class="sapUiSmallMargin" width="48%">
                <viz:VizFrame id="vizFrameTasks" uiConfig="{applicationSet:'fiori'}" vizType="pie" width="100%" height="320px">
                  <viz:dataset>
                    <vds:FlattenedDataset data="{view>/tasksByStatus}">
                      <vds:dimensions>
                        <vds:DimensionDefinition name="Status" value="{Status}"/>
                      </vds:dimensions>
                      <vds:measures>
                        <vds:MeasureDefinition name="Count" value="{Count}"/>
                      </vds:measures>
                    </vds:FlattenedDataset>
                  </viz:dataset>
                  <viz:feeds>
                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count"/>
                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                  </viz:feeds>
                </viz:VizFrame>
              </VBox>
              <VBox class="sapUiSmallMargin" width="48%">
                <viz:VizFrame id="vizFrameGoals" uiConfig="{applicationSet:'fiori'}" vizType="donut" width="100%" height="320px">
                  <viz:dataset>
                    <vds:FlattenedDataset data="{view>/goalsByStatus}">
                      <vds:dimensions>
                        <vds:DimensionDefinition name="Status" value="{Status}"/>
                      </vds:dimensions>
                      <vds:measures>
                        <vds:MeasureDefinition name="Count" value="{Count}"/>
                      </vds:measures>
                    </vds:FlattenedDataset>
                  </viz:dataset>
                  <viz:feeds>
                    <viz.feeds:FeedItem uid="size" type="Measure" values="Count"/>
                    <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"/>
                  </viz:feeds>
                </viz:VizFrame>
              </VBox>
            </HBox>
            <HBox>
              <Table id="revenueTable" items="{view>/RevenueRecords}">
                <columns>
                  <Column><Text text="Date"/></Column>
                  <Column><Text text="Amount"/></Column>
                  <Column><Text text="Sales User"/></Column>
                  <Column><Text text="Team"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{RecordDate}"/>
                      <Text text="{Amount}"/>
                      <Text text="{SalesUser/UserName}"/>
                      <Text text="{SalesUser/Team/Name}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </HBox>
          </VBox>
        </content>
      </Page>
</mvc:View>